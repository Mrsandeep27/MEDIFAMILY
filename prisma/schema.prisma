generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  password_hash  String
  name           String
  phone          String?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  members          Member[]
  family_members   FamilyMember[]

  @@map("users")
}

// ============================================================
// Family Groups — multi-device family sharing
// ============================================================
model Family {
  id          String   @id @default(uuid())
  name        String
  invite_code String   @unique
  created_by  String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  members FamilyMember[]

  @@index([invite_code])
  @@map("families")
}

model FamilyMember {
  id         String   @id @default(uuid())
  family_id  String
  user_id    String
  role       String   @default("member") // "admin" | "member"
  joined_at  DateTime @default(now())

  family Family @relation(fields: [family_id], references: [id])
  user   User   @relation(fields: [user_id], references: [id])

  @@unique([family_id, user_id])
  @@index([user_id])
  @@map("family_members")
}

model Member {
  id                      String   @id @default(uuid())
  user_id                 String
  name                    String
  relation                String   @default("self")
  date_of_birth           String?
  blood_group             String   @default("")
  gender                  String   @default("")
  allergies               String[] @default([])
  chronic_conditions      String[] @default([])
  emergency_contact_name  String?
  emergency_contact_phone String?
  avatar_url              String?
  abha_number             String?
  abha_address            String?
  is_deleted              Boolean  @default(false)
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt

  user           User           @relation(fields: [user_id], references: [id])
  records        HealthRecord[]
  medicines      Medicine[]
  reminders      Reminder[]
  share_links    ShareLink[]
  health_metrics HealthMetric[]

  @@index([user_id])
  @@map("members")
}

model HealthRecord {
  id             String   @id @default(uuid())
  member_id      String
  type           String   @default("prescription")
  title          String
  doctor_name    String?
  hospital_name  String?
  visit_date     String?
  diagnosis      String?
  notes          String?
  image_urls     String[] @default([])
  raw_ocr_text   String?
  ai_extracted   Json?
  tags           String[] @default([])
  is_deleted     Boolean  @default(false)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  member    Member     @relation(fields: [member_id], references: [id])
  medicines Medicine[]

  @@index([member_id])
  @@map("health_records")
}

model Medicine {
  id          String   @id @default(uuid())
  record_id   String
  member_id   String
  name        String
  dosage      String?
  frequency   String?
  duration    String?
  before_food Boolean  @default(false)
  start_date  String?
  end_date    String?
  is_active   Boolean  @default(true)
  is_deleted  Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  record  HealthRecord @relation(fields: [record_id], references: [id])
  member  Member       @relation(fields: [member_id], references: [id])

  @@index([member_id])
  @@index([record_id])
  @@map("medicines")
}

model Reminder {
  id            String   @id @default(uuid())
  medicine_id   String   @default("")
  member_id     String
  medicine_name String
  member_name   String
  dosage        String?
  before_food   Boolean  @default(false)
  time          String
  days          String[] @default([])
  is_active     Boolean  @default(true)
  is_deleted    Boolean  @default(false)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  member        Member        @relation(fields: [member_id], references: [id])
  reminder_logs ReminderLog[]

  @@index([member_id])
  @@map("reminders")
}

model ReminderLog {
  id           String   @id @default(uuid())
  reminder_id  String
  scheduled_at String
  status       String
  acted_at     String?
  is_deleted   Boolean  @default(false)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  reminder Reminder @relation(fields: [reminder_id], references: [id])

  @@index([reminder_id])
  @@map("reminder_logs")
}

model ShareLink {
  id         String   @id @default(uuid())
  member_id  String
  created_by String
  token      String   @unique
  record_ids String[] @default([])
  expires_at DateTime
  is_active  Boolean  @default(true)
  is_deleted Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  member      Member           @relation(fields: [member_id], references: [id])
  access_logs ShareAccessLog[]

  @@index([token])
  @@index([member_id])
  @@map("share_links")
}

model ShareAccessLog {
  id            String   @id @default(uuid())
  share_link_id String
  accessed_at   DateTime @default(now())

  share_link ShareLink @relation(fields: [share_link_id], references: [id])

  @@index([share_link_id])
  @@map("share_access_logs")
}

model HealthMetric {
  id          String   @id @default(uuid())
  member_id   String
  type        String
  value       Json
  recorded_at String
  notes       String?
  is_deleted  Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  member Member @relation(fields: [member_id], references: [id])

  @@index([member_id])
  @@map("health_metrics")
}

// ============================================================
// User Feedback & Reviews
// ============================================================
model Feedback {
  id         String   @id @default(uuid())
  user_id    String?
  user_email String?
  user_name  String?
  category   String   @default("review") // review, bug, feature, testimonial
  rating     Int?     // 1-5 stars
  message    String
  page       String?  // which page the feedback was from
  device     String?  // mobile/desktop
  status     String   @default("new") // new, read, resolved, archived
  admin_note String?
  created_at DateTime @default(now())

  @@index([category])
  @@index([status])
  @@map("feedback")
}

// ============================================================
// AI Doctor — self-improving rule engine
// ============================================================
// active_rules: rules currently injected into the AI Doctor's system
// instruction. Loaded with a 60s cache, so adding a rule takes effect
// nearly instantly without slowing down requests.
model ActiveRule {
  id          String   @id @default(uuid())
  rule_text   String   // the actual rule sentence ("NEVER suggest…")
  category    String   // safety | grounding | tone | dosage | red_flag
  severity    String   @default("normal") // low | normal | high | critical
  source      String   @default("manual") // manual | seed | auto_safe | from_candidate
  candidate_id String? // back-link to the candidate that produced this (if any)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([is_active])
  @@index([category])
  @@map("active_rules")
}

// rule_candidates: bad-answer signals get logged here. A meta-LLM call
// drafts a proposed rule, the admin reviews/edits/approves, and approved
// candidates spawn an ActiveRule.
model RuleCandidate {
  id              String   @id @default(uuid())
  // Source of the signal
  trigger_source  String   // safety_detector | user_thumbs_down | user_feedback
  trigger_reason  String   // human-readable reason ("AI suggested amoxicillin to penicillin-allergic patient")
  // The conversation that went wrong (JSON string of messages)
  conversation    String   // JSON: [{role, text}, ...]
  patient_brief   String?  // the brief sent with the request, for context
  ai_response     String?  // raw AI response that triggered the signal
  // The proposed rule (drafted by rule writer)
  proposed_rule   String?  // null until rule writer runs
  proposed_category String?
  proposed_severity String?
  // Review state
  status          String   @default("pending") // pending | approved | rejected | edited
  reviewer_email  String?
  reviewed_at     DateTime?
  // If admin edited the proposed rule before approving
  final_rule      String?
  user_id         String?  // who triggered the signal (for auditing, not exposed)
  created_at      DateTime @default(now())

  @@index([status])
  @@index([created_at])
  @@map("rule_candidates")
}

// ============================================================
// API Usage Tracking
// ============================================================
model ApiUsage {
  id         String   @id @default(uuid())
  feature    String   // medicine-info, lab-insights, extract, ai-doctor, medicine-chat
  model_used String   // gemini model that succeeded
  key_index  Int      // which API key was used (1-10)
  tokens_in  Int?     // estimated input tokens
  tokens_out Int?     // estimated output tokens
  duration   Int?     // response time in ms
  success    Boolean  @default(true)
  error      String?
  user_id    String?
  created_at DateTime @default(now())

  @@index([feature])
  @@index([created_at])
  @@map("api_usage")
}
